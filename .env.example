APP_NAME=ExamMentor API
ENVIRONMENT=development
APP_PUBLIC_URL=
APP_HOST=localhost
ACME_EMAIL=
SECRET_KEY=change-me
DATABASE_URL=sqlite:///./exammentor.db
REDIS_URL=redis://redis:6379/0
# Hosted object storage for session recordings.
# Examples:
# - AWS S3: https://s3.ap-south-1.amazonaws.com
# - Cloudflare R2: https://<accountid>.r2.cloudflarestorage.com
# - MinIO local fallback: http://minio:9000
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=false
S3_AUTO_CREATE_BUCKET=false

# Hosted LiveKit for POC.
# Examples:
# - LiveKit Cloud server URL
# - Self-hosted public URL such as https://rtc.example.com
LIVEKIT_URL=
LIVEKIT_PUBLIC_URL=
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
OPENAI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Local media fallback values if you intentionally want Docker-hosted LiveKit + MinIO:
# S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=minio123
# S3_BUCKET=exammentor
# S3_FORCE_PATH_STYLE=true
# S3_AUTO_CREATE_BUCKET=true
# LIVEKIT_URL=http://livekit:7880
# LIVEKIT_PUBLIC_URL=wss://localhost:3003
